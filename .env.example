# ============================================
# REQUIRED ENVIRONMENT VARIABLES
# ============================================
# These are needed for the app to work at runtime

# Coinbase Developer Platform credentials (for CDP wallet / x402 payments)
# Get these at https://docs.cdp.coinbase.com/api-reference/v2/authentication
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# OpenAI API key (for standard AI routes: gpt-4o, gpt-4o-mini)
# Get this at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# xAI Grok API key (for all Grok-branded routes: GrokDeepResearch, GrokAgentOrchestrator, etc.)
# Get this at https://console.x.ai/
XAI_API_KEY=

# ============================================
# HOW TO ADD TO VERCEL (IMPORTANT!)
# ============================================
# 1. Go to your Vercel project → Settings → Environment Variables
# 2. Add CDP_API_KEY_ID, CDP_API_KEY_SECRET, CDP_WALLET_SECRET, OPENAI_API_KEY, and XAI_API_KEY
#    for both Production and Preview environments
# 3. Redeploy

# ============================================
# OTHER SETTINGS
# ============================================
NETWORK=base
URL=http://localhost:3000

# Optional seller endpoint hardening
SELLER_API_KEY=
SELLER_RATE_LIMIT_PER_MINUTE=60
